{
  "expo": {
    "name": "OIO",
    "slug": "oio",
    "scheme": "linguaflow",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "bundleIdentifier": "com.yueyantech.oio",
      "supportsTablet": true
    },
    "android": {
      "package": "com.yueyantech.oio",
      "adaptiveIcon": {
        "foregroundImage": "./assets/app/logo.png",
        "backgroundColor": "#ffffff"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "favicon": "./assets/app/logo.png"
    },
    "extra": {
      "wechatAppId": "${EXPO_PUBLIC_WECHAT_APP_ID}",
      "eas": {
        "projectId": "0ca8f6d6-e389-43ec-8389-352d41df897b"
      }
    },
    "plugins": [
      "expo-web-browser",
      "expo-secure-store",
      "./plugins/with-wechat-pay"
    ]
  }
}
