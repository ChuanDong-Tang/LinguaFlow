{
    "name":  "linguaflow",
    "version":  "1.0.0",
    "private":  true,
    "type":  "module",
    "scripts":  {
                    "dev":  "node scripts/dev-all.mjs",
                    "dev:web":  "npm --prefix apps/web run dev",
                    "dev:mobile":  "npm --prefix apps/mobile run start",
                    "dev:api":  "npm --prefix api run dev",
                    "dev:worker":  "node --env-file-if-exists=.env --env-file-if-exists=.env.local --import tsx server/worker.dev.mjs",
                    "start:worker":  "node --env-file-if-exists=.env --env-file-if-exists=.env.local --import tsx server/worker.dev.mjs",
                    "dev:all":  "node scripts/dev-all.mjs",
                    "seed:dev-users":  "npm --prefix api run seed:dev-users",
                    "cleanup:fake-conversations":  "npm --prefix api run cleanup:fake-conversations"
    },
    "dependencies":  {
                         "@lf/core":  "file:packages/core",
                         "@prisma/client":  "^6.19.3",
                         "ioredis":  "^5.10.1",
                         "jszip":  "^3.10.1"
                     },
    "devDependencies":  {
                            "prisma":  "^6.19.3",
                            "tsx":  "^4.21.0"
                        }
}

