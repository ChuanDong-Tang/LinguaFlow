{
    "name":  "linguaflow-web",
    "version":  "1.0.0",
    "private":  true,
    "type":  "module",
    "scripts":  {
                    "dev":  "vite",
                    "build":  "vite build",
                    "preview":  "vite preview",
                    "dev:web":  "npm --prefix apps/web run dev",
                    "dev:mobile":  "npm --prefix apps/mobile run start",
                    "dev:api":  "npm --prefix api-next run dev",
                    "dev:worker":  "node --env-file-if-exists=.env --env-file-if-exists=.env.local --import tsx server-next/worker.dev.mjs",
                    "start:worker":  "node --env-file-if-exists=.env --env-file-if-exists=.env.local --import tsx server-next/worker.dev.mjs",
                    "dev:all":  "node scripts/dev-all.mjs",
                    "seed:dev-users":  "npm --prefix api-next run seed:dev-users",
                    "cleanup:fake-conversations":  "npm --prefix api-next run cleanup:fake-conversations"
                },
    "dependencies":  {
                         "@clerk/backend":  "^3.2.8",
                         "@clerk/clerk-js":  "^5.114.1",
                         "@lf/core":  "file:packages/core",
                         "@prisma/client":  "^6.19.3",
                         "@supabase/supabase-js":  "^2.103.0",
                         "ioredis":  "^5.10.1",
                         "jszip":  "^3.10.1",
                         "kokoro-js":  "^1.2.1",
                         "vite":  "^8.0.3"
                     },
    "devDependencies":  {
                            "prisma":  "^6.19.3",
                            "tsx":  "^4.21.0"
                        }
}

