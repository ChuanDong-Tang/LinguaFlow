generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("LF_DATABASE_URL")
}

model User {
  id             String             @id @default(cuid())
  nickname       String?
  email          String?
  phone          String?
  avatarUrl      String?
  status         UserStatus         @default(active)
  role           UserRole           @default(user)
  createdAt      DateTime           @default(now())
  updatedAt      DateTime           @updatedAt
  authIdentities UserAuthIdentity[]
  sessions       UserSession[]
  conversations  Conversation[]
  messages       Message[]
  entitlements   Entitlement[]
  subscriptions  Subscription[]
  autoRenewSubscriptions AutoRenewSubscription[]
  appleIapAccountLinks AppleIapAccountLink[]

  @@map("users")
  @@index([email])
  @@index([phone])
}

model UserAuthIdentity {
  userId         String
  provider       AuthProvider
  providerUserId String
  createdAt      DateTime     @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([provider, providerUserId])
  @@index([userId])
  @@map("user_auth_identities")
}

model UserSession {
  id                  String    @id @default(cuid())
  userId              String
  refreshTokenHash    String    @unique
  userAgent           String?
  ip                  String?
  expiresAt           DateTime
  revokedAt           DateTime?
  replacedBySessionId String?
  lastUsedAt          DateTime?
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([userId, revokedAt])
  @@index([expiresAt])
  @@map("user_sessions")
}

model Contact {
  id            String         @id @default(cuid())
  code          String         @unique
  name          String
  avatarUrl     String?
  kind          ContactKind    @default(ai_assistant)
  enabled       Boolean        @default(true)
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @default(now()) @updatedAt
  conversations Conversation[]

  @@map("contacts")
}

model Conversation {
  id         String    @id @default(cuid())
  userId     String
  contactId  String
  dateKey    String
  title      String?
  archivedAt DateTime?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  contact  Contact   @relation(fields: [contactId], references: [id], onDelete: Restrict)
  messages Message[]

  @@index([userId, updatedAt(sort: Desc)])
  @@index([userId, contactId, updatedAt(sort: Desc)])
  @@map("conversations")
  @@unique([userId, contactId, dateKey])
}

model Message {
  id               String        @id @default(cuid())
  conversationId   String
  userId           String
  role             MessageRole
  status           MessageStatus @default(pending)
  content          String
  inputChars       Int           @default(0)
  outputChars      Int           @default(0)
  clientId         String?
  sourceMessageId  String?       @unique
  clozeState       Json?
  clozeVersion     Int           @default(0)
  clozePracticeDiscardedAt DateTime?
  conversationDateKey String?
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([conversationId, conversationDateKey, createdAt])
  @@index([userId, conversationDateKey])
  @@index([conversationId, createdAt])
  @@index([userId, createdAt])
  @@index([userId, status, createdAt])
  @@unique([userId, conversationId, clientId])
  @@map("messages")
}

model Entitlement {
  id              String   @id @default(cuid())
  userId          String
  dateKey         String
  dailyTotalLimit Int
  usedTotalChars  Int      @default(0)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, dateKey])
  @@index([dateKey])
  @@map("entitlements")
}

model Subscription {
  id            String             @id @default(cuid())
  userId        String
  plan          SubscriptionPlan
  status        SubscriptionStatus
  startedAt     DateTime
  expiresAt     DateTime
  sourceOrderId String?            @unique
  createdAt     DateTime           @default(now())
  updatedAt     DateTime           @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, status, expiresAt])
  @@map("subscriptions")
}

model AutoRenewSubscription {
  id                  String                  @id @default(cuid())
  userId              String
  provider            AutoRenewProvider
  productCode          String
  status              AutoRenewStatus
  providerAgreementId String
  latestTransactionId String?
  currentPeriodStart  DateTime?
  currentPeriodEnd    DateTime?
  nextBillingAt       DateTime?
  cancelledAt         DateTime?
  metadata            Json?
  createdAt           DateTime                @default(now())
  updatedAt           DateTime                @updatedAt

  user    User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  charges AutoRenewCharge[]

  @@unique([provider, providerAgreementId])
  @@index([userId, status])
  @@index([status, nextBillingAt])
  @@map("auto_renew_subscriptions")
}

model AutoRenewCharge {
  id                      String                @id @default(cuid())
  autoRenewSubscriptionId String
  userId                  String
  provider                AutoRenewProvider
  productCode             String
  providerChargeId        String
  periodKey               String?
  status                  AutoRenewChargeStatus
  amount                  Int?
  currency                String?
  periodStart             DateTime?
  periodEnd               DateTime?
  paidAt                  DateTime?
  failedAt                DateTime?
  refundedAt              DateTime?
  errorCode               String?
  errorMessage            String?
  rawPayload              Json?
  createdAt               DateTime              @default(now())
  updatedAt               DateTime              @updatedAt

  subscription AutoRenewSubscription @relation(fields: [autoRenewSubscriptionId], references: [id], onDelete: Cascade)

  @@unique([provider, providerChargeId])
  @@unique([autoRenewSubscriptionId, periodKey])
  @@index([autoRenewSubscriptionId, createdAt])
  @@index([userId, createdAt])
  @@index([status, createdAt])
  @@map("auto_renew_charges")
}

model AppleIapAccountLink {
  appAccountToken       String   @id
  userId                String
  originalTransactionId String?
  latestTransactionId   String?
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@unique([originalTransactionId])
  @@map("apple_iap_account_links")
}

model AiRequestLog {
  id             String             @id @default(cuid())
  requestId      String
  userId         String
  conversationId String?
  userMessageId  String?
  provider       String
  model          String
  status         AiRequestLogStatus
  inputChars     Int                @default(0)
  outputChars    Int                @default(0)
  durationMs     Int?
  errorCode      String?
  errorMessage   String?
  createdAt      DateTime           @default(now())

  @@index([requestId])
  @@index([userId, createdAt])
  @@index([status, createdAt])
  @@map("ai_request_logs")
}

model PaymentOrder {
  id              String             @id @default(cuid())
  userId          String
  productCode     String
  sourceKey       String?
  provider        String
  providerOrderId String             @unique
  amount          Int
  currency        String             @default("CNY")
  status          PaymentOrderStatus @default(pending)
  metadata        Json?
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt

  @@index([userId, createdAt])
  @@index([productCode, sourceKey])
  @@index([status, createdAt])
  @@map("payment_orders")
}

model PaymentEvent {
  id              String             @id @default(cuid())
  provider        String
  providerEventId String
  providerOrderId String?
  eventType       String
  status          PaymentEventStatus @default(received)
  rawPayload      Json
  errorMessage    String?
  createdAt       DateTime           @default(now())
  processedAt     DateTime?

  @@unique([provider, providerEventId, eventType])
  @@index([providerOrderId])
  @@index([status, createdAt])
  @@map("payment_events")
}

model BenefitGrant {
  id            String             @id @default(cuid())
  userId        String
  sourceOrderId String
  productCode   String
  channel       String
  status        BenefitGrantStatus @default(pending)
  attemptCount  Int                @default(0)
  nextRetryAt   DateTime?
  lastErrorCode String?
  lastErrorMsg  String?
  payload       Json?
  createdAt     DateTime           @default(now())
  updatedAt     DateTime           @updatedAt
  processedAt   DateTime?

  @@unique([sourceOrderId, productCode])
  @@index([status, nextRetryAt, createdAt])
  @@index([userId, createdAt])
  @@map("benefit_grants")
}

model AdminAuditLog {
  id          String   @id @default(cuid())
  adminId     String
  action      String
  targetType  String
  targetId    String?
  requestId   String?
  ip          String?
  beforeData  Json?
  afterData   Json?
  reason      String?
  createdAt   DateTime @default(now())

  @@index([action, createdAt])
  @@index([targetType, targetId, createdAt])
  @@index([adminId, createdAt])
  @@map("admin_audit_logs")
}

model SystemEventLog {
  id           String                 @id @default(cuid())
  requestId    String?
  userId       String?
  module       String
  event        String
  level        SystemEventLogLevel
  status       SystemEventLogStatus
  errorCode    String?
  errorMessage String?
  metadata     Json?
  createdAt    DateTime               @default(now())

  @@index([requestId])
  @@index([userId, createdAt])
  @@index([module, event, createdAt])
  @@index([level, createdAt])
  @@index([status, createdAt])
  @@map("system_event_logs")
}

model TrustedCert {
  id            String   @id @default(cuid())
  provider      String
  keyId         String
  materialType  String
  pem           String
  fingerprint   String?
  notBefore     DateTime?
  notAfter      DateTime?
  status        String   @default("active")
  metadata      Json?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  lastSyncedAt  DateTime?

  @@unique([provider, keyId, materialType])
  @@index([provider, status, notAfter])
  @@map("trusted_certs")
}

enum UserStatus {
  active
  disabled
  pending_delete
}

enum UserRole {
  user
  admin
}

enum AuthProvider {
  authing
}

enum ContactKind {
  ai_assistant
}

enum MessageRole {
  user
  assistant
}

enum MessageStatus {
  pending
  success
  failed
}

enum AiRequestLogStatus {
  failed
  cancelled
  quota_exceeded
  task_in_progress
  rate_limited
}

enum PaymentOrderStatus {
  pending
  paid
  closed
  failed
  refunded
}

enum PaymentEventStatus {
  received
  processed
  ignored
  failed
}

enum BenefitGrantStatus {
  pending
  processing
  success
  failed
}

enum SubscriptionPlan {
  pro_monthly
}

enum SubscriptionStatus {
  active
  expired
  cancelled
}

enum AutoRenewProvider {
  wechat
  apple
}

enum AutoRenewStatus {
  pending
  active
  cancelled
  expired
  billing_retry
  paused
}

enum AutoRenewChargeStatus {
  scheduled
  pending
  paid
  failed
  refunded
}

enum SystemEventLogLevel {
  info
  warn
  error
}

enum SystemEventLogStatus {
  success
  failed
  ignored
}
