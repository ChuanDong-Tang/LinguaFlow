generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("LF_DATABASE_URL")
}

model User {
  id                     String                  @id @default(cuid())
  nickname               String?
  email                  String?
  phone                  String?
  avatarUrl              String?
  status                 UserStatus              @default(active)
  role                   UserRole                @default(user)
  createdAt              DateTime                @default(now())
  updatedAt              DateTime                @updatedAt
  authIdentities         UserAuthIdentity[]
  sessions               UserSession[]
  conversations          Conversation[]
  messages               Message[]
  ttsAssets              TtsAsset[]
  ttsRequestLogs         TtsRequestLog[]
  sttRequestLogs         SttRequestLog[]
  entitlements           Entitlement[]
  subscriptions          Subscription[]
  autoRenewSubscriptions AutoRenewSubscription[]
  appleIapAccountLinks   AppleIapAccountLink[]
  googlePlayAccountLinks GooglePlayAccountLink[]
  preference             UserPreference?
  profile                UserProfile?
  avatarAssets           UserAvatarAsset[]
  cards                  Card[]
  cardImageAssets        CardImageAsset[]
  cardPracticeStates     CardPracticeState[]
  cardSpeechAssets       CardSpeechAsset[]
  cardCollections        CardCollection[]
  cardEmbeddings         CardEmbedding[]
  phrases                Phrase[]
  phraseVariants         PhraseVariant[]
  phraseOccurrences      PhraseOccurrence[]
  cardEnrichmentJobs     CardEnrichmentJob[]
  recallSessions         RecallSession[]

  @@index([email])
  @@index([phone])
  @@map("users")
}

model UserProfile {
  userId             String   @id
  nickname           String
  nicknameSource     String   @default("default_generated")
  registrationMethod String
  avatarAssetId      String?  @unique
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  user        User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  avatarAsset UserAvatarAsset? @relation("CurrentUserAvatar", fields: [avatarAssetId], references: [id], onDelete: SetNull)

  @@index([nicknameSource, updatedAt])
  @@map("user_profiles")
}

model UserAvatarAsset {
  id                   String    @id @default(cuid())
  userId               String
  status               String    @default("pending")
  originalObjectKey    String
  uploadObjectKey      String?
  profileObjectKey     String?
  thumbnailObjectKey   String?
  mimeType             String
  fileSize             Int
  width                Int
  height               Int
  fileMd5              String?
  moderationRequestId  String?
  moderationSuggestion String?
  moderationLabel      String?
  moderationSubLabel   String?
  moderationScore      Float?
  moderatedAt          DateTime?
  expiresAt            DateTime?
  claimedAt            DateTime?
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt

  user              User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  currentForProfile UserProfile? @relation("CurrentUserAvatar")

  @@index([userId, createdAt])
  @@index([status, expiresAt])
  @@map("user_avatar_assets")
}

model Card {
  id                       String    @id @default(cuid())
  userId                   String
  dateKey                  String
  originalText             String?
  rewrittenText            String?
  languageCode             String
  appLocaleSnapshot        String
  promptDifficultySnapshot String
  promptVersion            String
  status                   String    @default("queued")
  clientId                 String
  inputChars               Int       @default(0)
  outputChars              Int       @default(0)
  isSample                 Boolean   @default(false)
  topic                    String?
  topicEditedAt            DateTime?
  collectionId             String?
  publishedAt              DateTime?
  processingAt             DateTime?
  leaseExpiresAt           DateTime?
  workerId                 String?
  failedAt                 DateTime?
  deletedAt                DateTime?
  createdAt                DateTime  @default(now())
  updatedAt                DateTime  @updatedAt

  user               User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  collection         CardCollection?      @relation(fields: [collectionId], references: [id], onDelete: SetNull)
  segments           CardRewriteSegment[]
  image              CardImageAsset?
  practiceState      CardPracticeState?
  speechAssets       CardSpeechAsset[]
  embeddings         CardEmbedding[]
  phraseOccurrences  PhraseOccurrence[]
  recallNodes        RecallSessionNode[]
  seedRecallSessions RecallSession[]      @relation("RecallSeedCard")

  @@unique([userId, clientId])
  @@index([userId, dateKey, createdAt])
  @@index([userId, status, createdAt])
  @@index([userId, collectionId, createdAt(sort: Desc)])
  @@index([collectionId])
  @@index([status, leaseExpiresAt, createdAt])
  @@index([publishedAt])
  @@map("cards")
}

model CardRewriteSegment {
  id         String   @id @default(cuid())
  entryId    String
  ordinal    Int
  text       String
  startUtf16 Int
  endUtf16   Int
  createdAt  DateTime @default(now())

  entry Card @relation(fields: [entryId], references: [id], onDelete: Cascade)

  @@unique([entryId, ordinal])
  @@index([entryId, startUtf16])
  @@map("card_rewrite_segments")
}

model CardImageAsset {
  id                   String    @id @default(cuid())
  userId               String
  entryId              String?   @unique
  status               String    @default("pending")
  originalObjectKey    String
  uploadObjectKey      String?
  thumbnailObjectKey   String?
  thumbnailStatus      String    @default("pending")
  thumbnailVersion     Int       @default(1)
  mimeType             String
  fileSize             Int
  width                Int
  height               Int
  fileMd5              String?
  moderationRequestId  String?
  moderationSuggestion String?
  moderationLabel      String?
  moderatedAt          DateTime?
  expiresAt            DateTime
  claimedAt            DateTime?
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  entry Card? @relation(fields: [entryId], references: [id], onDelete: SetNull)

  @@index([userId, createdAt])
  @@index([status, expiresAt])
  @@index([thumbnailStatus, updatedAt])
  @@map("card_image_assets")
}

model CardPracticeState {
  id                     String    @id @default(cuid())
  userId                 String
  cardId                 String    @unique
  clozeState             Json?
  clozeVersion           Int       @default(0)
  clozeLastResult        String?
  clozeCorrectStreak     Int       @default(0)
  clozeNextReviewAt      DateTime?
  dictationLastResult    String?
  dictationCorrectStreak Int       @default(0)
  dictationNextReviewAt  DateTime?
  createdAt              DateTime  @default(now())
  updatedAt              DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  card Card @relation(fields: [cardId], references: [id], onDelete: Cascade)

  @@index([userId, clozeNextReviewAt])
  @@index([userId, dictationNextReviewAt])
  @@map("card_practice_states")
}

model CardSpeechAsset {
  id                 String    @id @default(cuid())
  userId             String
  entryId            String?
  segmentId          String?
  sourceKind         String
  cacheKey           String    @unique
  provider           String
  voiceCode          String
  languageCode       String
  sourceText         String
  sourceTextHash     String
  status             String    @default("ready")
  objectKey          String
  objectUrl          String?
  objectUrlExpiresAt DateTime?
  durationMs         Int?
  wordMarks          Json?
  sentenceMarks      Json?
  lastAccessedAt     DateTime  @default(now())
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  entry Card? @relation(fields: [entryId], references: [id], onDelete: SetNull)

  @@index([userId, createdAt])
  @@index([entryId, sourceKind])
  @@index([status, updatedAt])
  @@index([sourceKind, lastAccessedAt])
  @@map("card_speech_assets")
}

model CardCollection {
  id             String   @id @default(cuid())
  userId         String
  name           String
  normalizedName String
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  user  User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  cards Card[]

  @@unique([userId, normalizedName])
  @@index([userId, updatedAt(sort: Desc)])
  @@map("card_collections")
}

model CardEmbedding {
  id           String                      @id @default(cuid())
  userId       String
  cardId       String
  provider     String
  model        String
  modelVersion String
  dimensions   Int
  inputHash    String
  embedding    Unsupported("vector(1536)")
  createdAt    DateTime                    @default(now())
  updatedAt    DateTime                    @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  card Card @relation(fields: [cardId], references: [id], onDelete: Cascade)

  @@unique([cardId, modelVersion])
  @@index([userId, modelVersion])
  @@map("card_embeddings")
}

model Phrase {
  id                String   @id @default(cuid())
  userId            String
  languageCode      String
  canonicalText     String
  canonicalKey      String
  status            String   @default("pending_normalization")
  normalizerVersion String
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  user        User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  variants    PhraseVariant[]
  occurrences PhraseOccurrence[]
  recallEdges RecallSessionEdge[]

  @@unique([userId, languageCode, canonicalKey])
  @@index([userId, languageCode, status])
  @@map("phrases")
}

model PhraseVariant {
  id                String   @id @default(cuid())
  phraseId          String
  userId            String
  languageCode      String
  surfaceText       String
  normalizedText    String
  source            String
  normalizerVersion String
  createdAt         DateTime @default(now())

  phrase Phrase @relation(fields: [phraseId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([phraseId, normalizedText])
  @@index([userId, languageCode, normalizedText])
  @@map("phrase_variants")
}

model PhraseOccurrence {
  id            String   @id @default(cuid())
  phraseId      String
  userId        String
  cardId        String
  cardCreatedAt DateTime
  sourceField   String
  segmentId     String?
  segmentKey    String   @default("")
  startUtf16    Int
  endUtf16      Int
  surfaceText   String
  matchType     String
  clozeBlankId  String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  phrase Phrase @relation(fields: [phraseId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  card   Card   @relation(fields: [cardId], references: [id], onDelete: Cascade)

  @@unique([phraseId, cardId, sourceField, segmentKey, startUtf16, endUtf16])
  @@index([phraseId, cardId])
  @@index([userId, cardId, sourceField, phraseId])
  @@index([userId, phraseId, sourceField, cardCreatedAt])
  @@map("phrase_occurrences")
}

model CardEnrichmentJob {
  id             String    @id @default(cuid())
  userId         String
  sourceKind     String
  sourceId       String
  jobType        String
  status         String    @default("queued")
  attempts       Int       @default(0)
  availableAt    DateTime  @default(now())
  processingAt   DateTime?
  leaseExpiresAt DateTime?
  workerId       String?
  inputHash      String
  inputVersion   String
  payload        Json?
  lastError      String?
  completedAt    DateTime?
  failedAt       DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, sourceKind, sourceId, jobType, inputVersion])
  @@index([status, availableAt, leaseExpiresAt, createdAt])
  @@index([userId, sourceKind, sourceId, createdAt])
  @@map("card_enrichment_jobs")
}

model RecallSession {
  id            String    @id @default(cuid())
  userId        String
  seedCardId    String
  launchMode    String
  launchContext Json?
  status        String    @default("active")
  lastOpenedAt  DateTime  @default(now())
  completedAt   DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  user     User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  seedCard Card                @relation("RecallSeedCard", fields: [seedCardId], references: [id], onDelete: Cascade)
  nodes    RecallSessionNode[]
  edges    RecallSessionEdge[]

  @@index([userId, status, updatedAt(sort: Desc)])
  @@map("recall_sessions")
}

model RecallSessionNode {
  id          String    @id @default(cuid())
  sessionId   String
  cardId      String
  state       String    @default("unvisited")
  ordinal     Int
  openedAt    DateTime?
  completedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  session       RecallSession       @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  card          Card                @relation(fields: [cardId], references: [id], onDelete: Cascade)
  outgoingEdges RecallSessionEdge[] @relation("RecallEdgeFrom")
  incomingEdges RecallSessionEdge[] @relation("RecallEdgeTo")

  @@unique([sessionId, cardId])
  @@unique([sessionId, ordinal])
  @@index([sessionId, state])
  @@map("recall_session_nodes")
}

model RecallSessionEdge {
  id           String   @id @default(cuid())
  sessionId    String
  fromNodeId   String
  toNodeId     String
  relationKey  String
  relationType String
  phraseId     String?
  reasons      Json
  isDirected   Boolean  @default(false)
  createdAt    DateTime @default(now())

  session  RecallSession     @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  fromNode RecallSessionNode @relation("RecallEdgeFrom", fields: [fromNodeId], references: [id], onDelete: Cascade)
  toNode   RecallSessionNode @relation("RecallEdgeTo", fields: [toNodeId], references: [id], onDelete: Cascade)
  phrase   Phrase?           @relation(fields: [phraseId], references: [id], onDelete: SetNull)

  @@unique([sessionId, fromNodeId, toNodeId, relationKey])
  @@index([sessionId, fromNodeId])
  @@index([sessionId, toNodeId])
  @@index([phraseId])
  @@map("recall_session_edges")
}

model UserPreference {
  userId                            String   @id
  appLocale                         String   @default("zh-CN")
  learningLanguage                  String   @default("en-US")
  promptDifficulty                  String   @default("native")
  guideState                        Json     @default("{}")
  ttsProvider                       String   @default("azure_global")
  ttsVoiceCode                      String?
  sttMultilingualRecognitionEnabled Boolean  @default(false)
  createdAt                         DateTime @default(now())
  updatedAt                         DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_preferences")
}

model UserAuthIdentity {
  userId         String
  provider       AuthProvider
  providerUserId String
  createdAt      DateTime     @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([provider, providerUserId])
  @@index([userId])
  @@map("user_auth_identities")
}

model UserSession {
  id                  String    @id @default(cuid())
  userId              String
  refreshTokenHash    String    @unique
  userAgent           String?
  ip                  String?
  expiresAt           DateTime
  revokedAt           DateTime?
  replacedBySessionId String?
  lastUsedAt          DateTime?
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([userId, revokedAt])
  @@index([expiresAt])
  @@map("user_sessions")
}

model Contact {
  id            String         @id @default(cuid())
  code          String         @unique
  name          String
  avatarUrl     String?
  kind          ContactKind    @default(ai_assistant)
  enabled       Boolean        @default(true)
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @default(now()) @updatedAt
  conversations Conversation[]

  @@map("contacts")
}

model Conversation {
  id         String    @id @default(cuid())
  userId     String
  contactId  String
  dateKey    String
  title      String?
  archivedAt DateTime?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  contact  Contact   @relation(fields: [contactId], references: [id], onDelete: Restrict)
  messages Message[]

  @@unique([userId, contactId, dateKey])
  @@index([userId, updatedAt(sort: Desc)])
  @@index([userId, contactId, updatedAt(sort: Desc)])
  @@map("conversations")
}

model Message {
  id                       String        @id @default(cuid())
  conversationId           String
  userId                   String
  role                     MessageRole
  status                   MessageStatus @default(pending)
  content                  String
  inputChars               Int           @default(0)
  outputChars              Int           @default(0)
  clientId                 String?
  sourceMessageId          String?       @unique
  clozeState               Json?
  clozeVersion             Int           @default(0)
  clozePracticeDiscardedAt DateTime?
  conversationDateKey      String?
  languageCode             String?
  createdAt                DateTime      @default(now())
  updatedAt                DateTime      @updatedAt

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  ttsAssets    TtsAsset[]

  @@unique([userId, conversationId, clientId])
  @@index([conversationId, conversationDateKey, createdAt])
  @@index([userId, conversationDateKey])
  @@index([conversationId, createdAt])
  @@index([userId, createdAt])
  @@index([userId, status, createdAt])
  @@map("messages")
}

model TtsAsset {
  id                 String    @id @default(cuid())
  userId             String
  messageId          String
  provider           String
  voiceCode          String
  languageCode       String
  sourceKey          String    @default("rewrite")
  sourceText         String
  sourceTextHash     String
  format             String    @default("mp3")
  status             String    @default("ready")
  objectKey          String
  objectUrl          String?
  objectUrlExpiresAt DateTime?
  durationMs         Int?
  wordMarks          Json?
  sentenceMarks      Json?
  errorMessage       String?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  message Message @relation(fields: [messageId], references: [id], onDelete: Cascade)

  @@unique([messageId, provider, voiceCode, languageCode, sourceKey, sourceTextHash])
  @@index([userId, createdAt])
  @@index([messageId])
  @@index([status, updatedAt])
  @@map("tts_assets")
}

model TtsRequestLog {
  id              String   @id @default(cuid())
  requestId       String?
  userId          String
  messageId       String
  assetId         String?
  provider        String
  voiceCode       String
  languageCode    String
  sourceTextHash  String
  sourceTextChars Int
  cacheHit        Boolean  @default(false)
  deduped         Boolean  @default(false)
  status          String
  durationMs      Int?
  errorCode       String?
  errorMessage    String?
  createdAt       DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([requestId])
  @@index([userId, createdAt])
  @@index([status, createdAt])
  @@index([provider, languageCode, createdAt])
  @@map("tts_request_logs")
}

model SttRequestLog {
  id                          String   @id @default(cuid())
  requestId                   String?
  userId                      String
  provider                    String
  mode                        String   @default("realtime")
  languageIdMode              String
  candidateLanguages          Json
  detectedLanguage            String?
  languageDetectionConfidence String?
  audioFormat                 String   @default("pcm_s16le")
  sampleRate                  Int
  channels                    Int
  bitsPerSample               Int
  audioBytes                  Int      @default(0)
  audioDurationMs             Int      @default(0)
  billableSeconds             Int      @default(0)
  transcriptChars             Int      @default(0)
  recognizedTextPresent       Boolean  @default(false)
  status                      String
  durationMs                  Int?
  errorCode                   String?
  errorMessage                String?
  createdAt                   DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([requestId])
  @@index([userId, createdAt])
  @@index([status, createdAt])
  @@index([provider, languageIdMode, createdAt])
  @@map("stt_request_logs")
}

model Entitlement {
  id              String   @id @default(cuid())
  userId          String
  dateKey         String
  dailyTotalLimit Int
  usedTotalChars  Int      @default(0)
  imageLimit      Int      @default(0)
  usedImages      Int      @default(0)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, dateKey])
  @@index([dateKey])
  @@map("entitlements")
}

model Subscription {
  id            String             @id @default(cuid())
  userId        String
  plan          SubscriptionPlan
  status        SubscriptionStatus
  startedAt     DateTime
  expiresAt     DateTime
  sourceOrderId String?            @unique
  createdAt     DateTime           @default(now())
  updatedAt     DateTime           @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, status, expiresAt])
  @@map("subscriptions")
}

model AutoRenewSubscription {
  id                  String            @id @default(cuid())
  userId              String
  provider            AutoRenewProvider
  productCode         String
  status              AutoRenewStatus
  providerAgreementId String
  latestTransactionId String?
  currentPeriodStart  DateTime?
  currentPeriodEnd    DateTime?
  nextBillingAt       DateTime?
  cancelledAt         DateTime?
  metadata            Json?
  createdAt           DateTime          @default(now())
  updatedAt           DateTime          @updatedAt

  user    User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  charges AutoRenewCharge[]

  @@unique([provider, providerAgreementId])
  @@index([userId, status])
  @@index([status, nextBillingAt])
  @@map("auto_renew_subscriptions")
}

model AutoRenewCharge {
  id                      String                @id @default(cuid())
  autoRenewSubscriptionId String
  userId                  String
  provider                AutoRenewProvider
  productCode             String
  providerChargeId        String
  periodKey               String?
  status                  AutoRenewChargeStatus
  amount                  Int?
  currency                String?
  periodStart             DateTime?
  periodEnd               DateTime?
  paidAt                  DateTime?
  failedAt                DateTime?
  refundedAt              DateTime?
  errorCode               String?
  errorMessage            String?
  rawPayload              Json?
  createdAt               DateTime              @default(now())
  updatedAt               DateTime              @updatedAt

  subscription AutoRenewSubscription @relation(fields: [autoRenewSubscriptionId], references: [id], onDelete: Cascade)

  @@unique([provider, providerChargeId])
  @@unique([autoRenewSubscriptionId, periodKey])
  @@index([autoRenewSubscriptionId, createdAt])
  @@index([userId, createdAt])
  @@index([status, createdAt])
  @@map("auto_renew_charges")
}

model AppleIapAccountLink {
  appAccountToken       String   @id
  userId                String
  originalTransactionId String?
  latestTransactionId   String?
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([originalTransactionId])
  @@index([userId])
  @@map("apple_iap_account_links")
}

model GooglePlayAccountLink {
  obfuscatedAccountId String   @id
  userId              String
  purchaseToken       String?
  latestOrderId       String?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([purchaseToken])
  @@index([userId])
  @@map("google_play_account_links")
}

model AiRequestLog {
  id             String             @id @default(cuid())
  requestId      String
  userId         String
  conversationId String?
  userMessageId  String?
  provider       String
  model          String
  status         AiRequestLogStatus
  inputChars     Int                @default(0)
  outputChars    Int                @default(0)
  durationMs     Int?
  errorCode      String?
  errorMessage   String?
  createdAt      DateTime           @default(now())

  @@index([requestId])
  @@index([userId, createdAt])
  @@index([status, createdAt])
  @@map("ai_request_logs")
}

model PaymentOrder {
  id              String             @id @default(cuid())
  userId          String
  productCode     String
  sourceKey       String?
  provider        String
  providerOrderId String             @unique
  amount          Int
  currency        String             @default("CNY")
  status          PaymentOrderStatus @default(pending)
  metadata        Json?
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt

  @@index([userId, createdAt])
  @@index([productCode, sourceKey])
  @@index([status, createdAt])
  @@map("payment_orders")
}

model PaymentEvent {
  id              String             @id @default(cuid())
  provider        String
  providerEventId String
  providerOrderId String?
  eventType       String
  status          PaymentEventStatus @default(received)
  rawPayload      Json
  errorMessage    String?
  createdAt       DateTime           @default(now())
  processedAt     DateTime?

  @@unique([provider, providerEventId, eventType])
  @@index([providerOrderId])
  @@index([status, createdAt])
  @@map("payment_events")
}

model BenefitGrant {
  id            String             @id @default(cuid())
  userId        String
  sourceOrderId String
  productCode   String
  channel       String
  status        BenefitGrantStatus @default(pending)
  attemptCount  Int                @default(0)
  nextRetryAt   DateTime?
  lastErrorCode String?
  lastErrorMsg  String?
  payload       Json?
  createdAt     DateTime           @default(now())
  updatedAt     DateTime           @updatedAt
  processedAt   DateTime?

  @@unique([sourceOrderId, productCode])
  @@index([status, nextRetryAt, createdAt])
  @@index([userId, createdAt])
  @@map("benefit_grants")
}

model AdminAuditLog {
  id         String   @id @default(cuid())
  adminId    String
  action     String
  targetType String
  targetId   String?
  requestId  String?
  ip         String?
  beforeData Json?
  afterData  Json?
  reason     String?
  createdAt  DateTime @default(now())

  @@index([action, createdAt])
  @@index([targetType, targetId, createdAt])
  @@index([adminId, createdAt])
  @@map("admin_audit_logs")
}

model SystemEventLog {
  id           String               @id @default(cuid())
  requestId    String?
  userId       String?
  module       String
  event        String
  level        SystemEventLogLevel
  status       SystemEventLogStatus
  errorCode    String?
  errorMessage String?
  metadata     Json?
  createdAt    DateTime             @default(now())

  @@index([requestId])
  @@index([userId, createdAt])
  @@index([module, event, createdAt])
  @@index([level, createdAt])
  @@index([status, createdAt])
  @@map("system_event_logs")
}

model TrustedCert {
  id           String    @id @default(cuid())
  provider     String
  keyId        String
  materialType String
  pem          String
  fingerprint  String?
  notBefore    DateTime?
  notAfter     DateTime?
  status       String    @default("active")
  metadata     Json?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  lastSyncedAt DateTime?

  @@unique([provider, keyId, materialType])
  @@index([provider, status, notAfter])
  @@map("trusted_certs")
}

