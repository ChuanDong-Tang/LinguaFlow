{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "types": [],
    "strict": false,
    "skipLibCheck": true,
    "noEmit": true
  },
  "include": ["packages/**/*.ts", "api/**/*.ts", "server/**/*.ts", "apps/mobile/**/*.ts", "apps/web/**/*.ts"]
}
